# --- Environments ---
# Folders created by venv, virtualenv, or conda
venv/
.venv/
env/
ENV/
bin/
lib/
include/

# --- Python Artifacts ---
# Compiled python files
__pycache__/
*.py[cod]
*$py.class
*.so

