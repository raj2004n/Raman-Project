# If you save models or logs, ignore the heavy stuff
logs/
*.ckpt
*.h5
*.pb
*.tflite
*.npy
*.npz

# --- Jupyter Notebooks ---
.ipynb_checkpoints

# --- Distribution / Packaging ---
# If you ever build your own package
dist/
build/
*.egg-info/

# --- OS Specific ---
.DS_Store
Thumbs.db